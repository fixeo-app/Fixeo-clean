{
  "version": 2,
  "builds": [
    {
      "src": "api/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.xml",
      "use": "@vercel/static"
    },
    {
      "src": "*.txt",
      "use": "@vercel/static"
    },
    {
      "src": "css/**",
      "use": "@vercel/static"
    },
    {
      "src": "js/**",
      "use": "@vercel/static"
    },
    {
      "src": "image/**",
      "use": "@vercel/static"
    },
    {
      "src": "uploads/**",
      "use": "@vercel/static"
    },
    {
      "src": "img/**",
      "use": "@vercel/static"
    },
    {
      "src": "data/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/artisan/(.*)",
      "dest": "/artisan-profile.html"
    },
    {
      "comment": "SEO clean URLs — /service/city → service-city.html (additive, zero breakage to existing .html routes)",
      "src": "^/plombier/([a-z][a-z-]*)$",
      "dest": "/plombier-$1.html"
    },
    {
      "src": "^/electricien/([a-z][a-z-]*)$",
      "dest": "/electricien-$1.html"
    },
    {
      "src": "^/serrurier/([a-z][a-z-]*)$",
      "dest": "/serrurier-$1.html"
    },
    {
      "src": "^/climatisation/([a-z][a-z-]*)$",
      "dest": "/climatisation-$1.html"
    },
    {
      "src": "^/peinture/([a-z][a-z-]*)$",
      "dest": "/peinture-$1.html"
    },
    {
      "comment": "City hub pages — /villes/city → city landing (future)",
      "src": "^/villes/([a-z][a-z-]*)$",
      "dest": "/villes-$1.html"
    },
    {
      "comment": "Service hub pages — /services/service → services page (future)",
      "src": "^/services/([a-z][a-z-]*)$",
      "dest": "/services.html"
    },
    {
      "comment": "Blog routing — /blog/slug → blog engine (Phase 4)",
      "src": "^/blog/([a-z][a-z0-9-]*)$",
      "dest": "/blog/$1.html"
    },
    {
      "comment": "Blog index — /blog → blog-index.html (Phase 4)",
      "src": "^/blog/?$",
      "dest": "/blog-index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },
    {
      "source": "/artisan/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },
    {
      "source": "/(.*)\\.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/data/(.*)\\.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
